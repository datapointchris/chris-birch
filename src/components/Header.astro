---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import PreferencesPicker from './PreferencesPicker.astro';
---

<header class="site-header">
	<div class="site-header__top">
		<h2 class="site-header__title"><a href="/">{SITE_TITLE}</a></h2>
		<PreferencesPicker />
	</div>
	<nav class="site-nav">
		<ul>
			<li><HeaderLink href="/">Home</HeaderLink></li>
			<li><HeaderLink href="/blog">Blog</HeaderLink></li>
			<li><HeaderLink href="/about">About</HeaderLink></li>
		</ul>
	</nav>
</header>

<style>
	.site-header {
		padding: var(--space-m) var(--space-m) 0 var(--space-m);
	}

	.site-header__top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 90%;
		margin: 0 auto var(--space-s) auto;
	}

	.site-header__title {
		margin: 0;
		font-size: var(--fs-700);
		font-weight: 700;
		text-shadow: var(--deep-3d-text-shadow);
		color: var(--clr-accent-light);
	}

	.site-header__title a {
		color: inherit;
		text-decoration: none;
	}

	.site-nav {
		display: flex;
		justify-content: center;
	}

	.site-nav ul {
		list-style: none;
		display: inline-flex;
		align-items: center;
		gap: var(--space-2xs);
		margin: 0;
		padding: var(--space-2xs);
		background-color: var(--clr-primary);
		border-radius: 999px;
		box-shadow: var(--floating-box);
		font-size: var(--fs-500);
		font-weight: 700;
	}

	.site-nav li {
		display: flex;
	}

	.site-nav ul li :global(a) {
		display: inline-block;
		padding: var(--space-2xs) var(--space-m);
		border-radius: 999px;
		text-decoration: none;
		transition:
			color 0.15s ease,
			background-color 0.15s ease,
			box-shadow 0.15s ease,
			transform 0.15s ease;
	}

	.site-nav ul li :global(a:hover) {
		background-color: var(--clr-primary--lighter);
		box-shadow: var(--floating-box);
		transform: translateY(-1px);
		text-decoration: none;
	}

	.site-nav ul li :global(a.active),
	.site-nav ul li :global(a.active:hover) {
		background-color: var(--clr-primary--darker);
		box-shadow: var(--floating-box-pressed);
		transform: none;
	}

	@media screen and (max-width: 600px) {
		.site-header__top {
			max-width: 100%;
		}
		.site-nav ul {
			flex-wrap: wrap;
			justify-content: center;
		}
	}
</style>
